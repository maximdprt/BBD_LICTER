# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Legacy nested app folder (project root is repo root). Safe to delete locally if still present.
/BBD_LICTER/

# dependencies (any folder named node_modules — avoids 10k+ accidental commits)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js — .next anywhere; export output at repo root only
.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
